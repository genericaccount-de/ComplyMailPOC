# Application configuration has moved to YAML files:
#   backend/config.yaml    (see backend/config.example.yaml)
#   smtp-proxy/config.yaml (see smtp-proxy/config.example.yaml)
#
# Config values may reference environment variables via ${VAR} syntax, which
# are resolved when the YAML is loaded. backend/config.yaml references the
# following for llm.api_key, so it must be set in the environment:
LLM_API_KEY=your-api-key-here
