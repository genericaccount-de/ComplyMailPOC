# Mistral API
MISTRAL_API_KEY=your-api-key-here
MISTRAL_API_URL=https://api.mistral.ai

# Backend API
API_LISTEN_ADDR=:8080

# SMTP Proxy
SMTP_LISTEN_ADDR=:2525
SMTP_UPSTREAM_HOST=mail.example.com
SMTP_UPSTREAM_PORT=25

# Backend URL (used by smtp-proxy to call backend)
BACKEND_API_URL=http://api:8080
