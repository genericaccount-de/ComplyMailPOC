# Application configuration has moved to YAML files:
#   backend/config.yaml    (see backend/config.example.yaml)
#   smtp-proxy/config.yaml (see smtp-proxy/config.example.yaml)
#
# The only value still read from the environment is the LLM API key,
# which can be injected at runtime to keep secrets out of the config files.
# Used by docker-compose to override llm.api_key in backend/config.yaml.
LLM_API_KEY=your-api-key-here
